{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "electron/preload.ts"
  ],
  "ignoreDependencies": [
    "wait-on",
    // Node builtin (node:sqlite) — not an npm package, never in package.json.
    "node:sqlite"
  ],
  // ProviderId existe a propósito en dos capas: la runtime (union estricta en
  // ai/providers) y la de storage (string laxo en db/types). Los consumidores
  // los importan con alias (RuntimeProviderId / DbProviderId).
  "ignoreExports": [
    { "file": "electron/db/types.ts", "exports": ["ProviderId"] }
  ],
  "duplicates": {
    // Hide pair-only clones; focus on widespread copy-paste
    // worth refactoring. Lower to 2 to report every duplicate pair.
    "minOccurrences": 3
    // Common additions (uncomment to enable):
    // "ignore": [
    //   "**/lib/**",          // for repos that publish transpiled output to lib/
    //   "**/legacy/**",       // for repos with legacy-build artifacts
    //   "**/__generated__/**", // Relay, GraphQL Code Generator
    //   "**/generated/**"     // OpenAPI, Protobuf codegen
    // ]
  },
  "rules": {}
}
