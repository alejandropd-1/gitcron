{
  "name": "gitcron",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:electron": "tsup electron/main.ts electron/preload.ts --external electron --format cjs --outDir dist",
    "electron:dev": "concurrently \"next dev\" \"npm run build:electron -- --watch\" \"wait-on http://localhost:3000 && electron .\"",
    "start": "next start",
    "lint": "eslint .",
    "clean": "next clean",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "package:build": "next build && npm run build:electron",
    "package": "npm run package:build && electron-builder",
    "package:win": "npm run package:build && electron-builder --win",
    "package:mac": "npm run package:build && electron-builder --mac",
    "package:linux": "npm run package:build && electron-builder --linux"
  },
  "build": {
    "appId": "com.alejandropd.gitcron",
    "productName": "GitCron",
    "copyright": "Copyright © 2026 Alejandro Delgado",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**",
      "out/**",
      "public/**",
      "package.json"
    ],
    "extraResources": [
      { "from": "public/favicon.ico", "to": "favicon.ico" },
      { "from": "public/gitcron-icon.png", "to": "gitcron-icon.png" }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "public/gitcron-icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "public/gitcron-icon.png",
      "category": "Development"
    }
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.38.0",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.6",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "fallow": "^2.74.0",
    "tailwindcss": "4.1.11",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  }
}
