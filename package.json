{
  "name": "gitcron",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:electron": "tsup electron/main.ts electron/preload.ts --external electron --format cjs --outDir dist",
    "electron:dev": "concurrently \"next dev\" \"npm run build:electron -- --watch\" \"wait-on http://localhost:3000 && electron .\"",
    "start": "next start",
    "lint": "eslint .",
    "clean": "next clean"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "@hookform/resolvers": "^5.2.1",
    "@octokit/rest": "^22.0.1",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-is-dev": "^3.0.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.38.0",
    "next": "^15.4.9",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "tailwindcss": "4.1.11",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "wait-on": "^9.0.10"
  }
}
